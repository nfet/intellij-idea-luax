<?xml version="1.0" encoding="UTF-8"?>
<templateSet group="Lua">
    <template name="logf"
              value="print(&quot;[DEBUG] $FUNCTION$() called&quot;)"
              description="Print function name debug message"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

    <template name="log key values from selection"
              value="print(&quot;[DEBUG] $FUNCTION$&quot;, $RESULT$$END$)"
              description="Given a selection value of x,y, this will log using: (&quot;[DEBUG]&quot;, &apos;x=&apos;, x, &apos;y=&apos;, y)"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <variable name="RESULT"
                  expression="luaCSVSelection(SELECTION)"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>
    <template name="log key values from clipboard"
              value="print(&quot;[DEBUG] $FUNCTION$&quot;, $RESULT$$END$)"
              description="Given a copy buffer of x,y -- this will log with print(&quot;[DEBUG]&quot;, &apos;x=&apos;, x, &apos;y=&apos;, y)"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <variable name="RESULT"
                  expression="luaCSVSelection(clipboard())"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

</templateSet>

<?xml version="1.0" encoding="UTF-8"?>
<templateSet group="Lua">
    <template name="logf"
              value="print(&quot;[DEBUG] $FUNCTION$() called&quot;)"
              description="Print function name debug message"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

    <template name="func"
              value="function $NAME$($PARAMS$)$END$&#10;end"
              description="Create new function"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true"/>
        <variable name="PARAMS" expression="" defaultValue="..." alwaysStopAt="true"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

    <template name="log key values"
              value="print(&quot;[DEBUG]&quot;, $RESULT$$END$)"
              description="Log key-value pairs"
              toReformat="true"
              toShortenFQNames="true">

        <variable name="RESULT"
                  expression="luaCSVSelection(SELECTION)"
                  defaultValue=""
                  alwaysStopAt="false"/>

        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

</templateSet>

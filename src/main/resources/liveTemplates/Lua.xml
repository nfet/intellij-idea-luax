<?xml version="1.0" encoding="UTF-8"?>
<templateSet group="Lua">
    <template name="logf"
              value="print(&quot;[DEBUG] $FUNCTION$() called&quot;)"
              key="template.logf.description"
              resource-bundle="messages.MyMessageBundle"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

    <template name="log key values from selection"
              value="print(&quot;[DEBUG] $FUNCTION$&quot;, $RESULT$$END$)"
              key="template.logKeyValuesFromSelection.description"
              resource-bundle="messages.MyMessageBundle"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <variable name="RESULT"
                  expression="luaCSVSelection(SELECTION)"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>
    <template name="log key values from clipboard"
              value="print(&quot;[DEBUG] $FUNCTION$&quot;, $RESULT$$END$)"
              key="template.logKeyValuesFromClipboard.description"
              resource-bundle="messages.MyMessageBundle"
              toReformat="true"
              toShortenFQNames="true">
        <variable name="FUNCTION"
                  expression="luaFunctionName()"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <variable name="RESULT"
                  expression="luaCSVSelection(clipboard())"
                  defaultValue=""
                  alwaysStopAt="false"/>
        <context>
            <option name="LUAX" value="true"/>
        </context>
    </template>

</templateSet>
